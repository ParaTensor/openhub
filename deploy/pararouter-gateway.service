[Unit]
Description=Pararouter Rust Gateway
After=network.target pararouter-hub.service

[Service]
Type=simple
User=__SERVICE_USER__
WorkingDirectory=__PROJECT_DIR__/gateway
ExecStart=__PROJECT_DIR__/gateway/bin/gateway
Restart=always
RestartSec=3
Environment=RUST_LOG=info
Environment=DATABASE_URL=postgres://xinference:password@localhost:5432/pararouter

[Install]
WantedBy=multi-user.target
