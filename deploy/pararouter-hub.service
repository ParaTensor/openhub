[Unit]
Description=Pararouter Node Service (Hub)
After=network.target postgresql.service

[Service]
Type=simple
User=__SERVICE_USER__
WorkingDirectory=__PROJECT_DIR__
ExecStart=/usr/bin/npm run dev -w @pararouter/hub
Restart=always
RestartSec=3
EnvironmentFile=-__SERVICE_HOME__/.pararouter.env
Environment=NODE_ENV=production
Environment=PORT=3000
Environment=DATABASE_URL=postgres://xinference:password@localhost:5432/pararouter

[Install]
WantedBy=multi-user.target
