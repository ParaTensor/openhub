[Unit]
Description=OpenHub Node Service (Hub)
After=network.target postgresql.service

[Service]
Type=simple
User=mac-m4
WorkingDirectory=/home/mac-m4/openhub
ExecStart=/usr/bin/npm run dev -w @openhub/hub
Restart=always
RestartSec=3
EnvironmentFile=-/home/mac-m4/.openhub.env
Environment=PORT=3000

[Install]
WantedBy=multi-user.target
