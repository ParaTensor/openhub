{
  "entities": {
    "Model": {
      "title": "Model",
      "description": "Information about an LLM model.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique model ID." },
        "name": { "type": "string", "description": "Display name of the model." },
        "provider": { "type": "string", "description": "Provider name (e.g., OpenAI, Anthropic)." },
        "type": { "type": "string", "description": "Model type (e.g., chat, embedding)." },
        "status": { "type": "string", "enum": ["online", "offline"], "description": "Current status." },
        "latency": { "type": "number", "description": "Average latency in ms." },
        "uptime": { "type": "string", "description": "Uptime percentage." }
      },
      "required": ["id", "name", "provider", "status"]
    },
    "ProviderKey": {
      "title": "ProviderKey",
      "description": "API key for an LLM provider (e.g., OpenAI).",
      "type": "object",
      "properties": {
        "provider": { "type": "string", "description": "Provider name." },
        "key": { "type": "string", "description": "The API key." },
        "status": { "type": "string", "enum": ["active", "inactive"], "description": "Status of the key." }
      },
      "required": ["provider", "key", "status"]
    },
    "UserApiKey": {
      "title": "UserApiKey",
      "description": "API key for a user to access OpenHub.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Display name of the key." },
        "key": { "type": "string", "description": "The API key (hashed or masked)." },
        "uid": { "type": "string", "description": "Owner UID." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." },
        "lastUsed": { "type": "string", "description": "Last usage description." },
        "usage": { "type": "string", "description": "Usage amount." }
      },
      "required": ["name", "key", "uid", "createdAt"]
    },
    "Activity": {
      "title": "Activity",
      "description": "Log of API usage.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "number", "description": "When the request occurred." },
        "model": { "type": "string", "description": "Model used." },
        "latency": { "type": "number", "description": "Request latency in ms." },
        "tokens": { "type": "number", "description": "Tokens consumed." },
        "status": { "type": "number", "description": "HTTP status code." },
        "user_id": { "type": "string", "description": "User ID who made the request." }
      },
      "required": ["timestamp", "model", "status"]
    },
    "Gateway": {
      "title": "Gateway",
      "description": "Registered gateway instance",
      "type": "object",
      "properties": {
        "instance_id": { "type": "string" },
        "status": { "type": "string" },
        "last_seen": { "type": "string", "format": "date-time" }
      },
      "required": ["instance_id"]
    }
  },
  "firestore": {
    "/models/{modelId}": {
      "schema": "Model",
      "description": "Collection of available LLM models."
    },
    "/provider_keys/{keyId}": {
      "schema": "ProviderKey",
      "description": "Collection of provider API keys (OpenAI, etc.)."
    },
    "/user_api_keys/{keyId}": {
      "schema": "UserApiKey",
      "description": "Collection of user-generated API keys for OpenHub."
    },
    "/activity/{activityId}": {
      "schema": "Activity",
      "description": "Collection of API usage logs."
    },
    "/gateways/{gatewayId}": {
      "schema": "Gateway",
      "description": "Registered gateways"
    }
  }
}
