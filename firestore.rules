rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: models
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - provider: string (required)
    //   - type: string (optional)
    //   - status: string (required, enum: ['online', 'offline'])
    //   - latency: number (optional)
    //   - uptime: string (optional)
    //
    // Collection: provider_keys
    // Fields:
    //   - provider: string (required)
    //   - key: string (required)
    //   - status: string (required, enum: ['active', 'inactive'])
    //
    // Collection: user_api_keys
    // Fields:
    //   - name: string (required)
    //   - key: string (required)
    //   - uid: string (required)
    //   - createdAt: string (required)
    //   - lastUsed: string (optional)
    //   - usage: string (optional)
    //
    // Collection: activity
    // Fields:
    //   - timestamp: string (required, ISO 8601)
    //   - model: string (required)
    //   - provider: string (required)
    //   - latency: number (optional)
    //   - tokens: number (optional)
    //   - status: number (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "lipeng.sh@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidStatus(status) {
      return status in ['online', 'offline'];
    }

    function isValidKeyStatus(status) {
      return status in ['active', 'inactive'];
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidModel(data) {
      return hasRequiredFields(['id', 'name', 'provider', 'status']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.provider is string && data.provider.size() > 0 && data.provider.size() < 100 &&
             isValidStatus(data.status);
    }

    function isValidProviderKey(data) {
      return hasRequiredFields(['provider', 'key', 'status']) &&
             data.provider is string && data.provider.size() > 0 && data.provider.size() < 100 &&
             data.key is string && data.key.size() > 0 && data.key.size() < 200 &&
             isValidKeyStatus(data.status);
    }

    function isValidUserApiKey(data) {
      return hasRequiredFields(['name', 'key', 'uid', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.key is string && data.key.size() > 0 && data.key.size() < 200 &&
             data.uid == request.auth.uid &&
             data.createdAt is string;
    }

    function isValidActivity(data) {
      return hasRequiredFields(['timestamp', 'model', 'status']) &&
             data.timestamp is number &&
             data.model is string &&
             data.status is number;
    }

    function isValidGateway(data) {
      return hasRequiredFields(['instance_id', 'status']) &&
             data.instance_id is string &&
             data.status is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Models: Admins can manage, authenticated users can read
    match /models/{modelId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidModel(request.resource.data);
      allow delete: if isAdmin();
    }

    // Provider Keys: Only admins can manage and read
    match /provider_keys/{keyId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin() && isValidProviderKey(request.resource.data);
      allow delete: if isAdmin();
    }

    // User API Keys: Users can manage their own keys
    match /user_api_keys/{keyId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidUserApiKey(request.resource.data);
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && isValidUserApiKey(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Activity: Admins can read, system can write
    match /activity/{activityId} {
      allow read: if isAdmin();
      allow create: if isValidActivity(request.resource.data); // Allow server-side writes
    }

    // Gateways: Admins can read, system can write
    match /gateways/{gatewayId} {
      allow read: if isAdmin();
      allow create, update: if isValidGateway(request.resource.data); // Allow server-side writes
    }

    // Users: Users can read their own profile, admins can manage
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAuthenticated() && request.auth.uid == userId && 
                             (request.resource.data.role == 'user' || (resource != null && request.resource.data.role == resource.data.role));
      allow write: if isAdmin();
    }
  }
}
